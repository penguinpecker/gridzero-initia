# ── gridZERO initia resolver / fulfiller bot ───────────────────────────────
# Copy to `.env` and fill in. NEVER commit the real .env.

# Published address of the gridzero Move package (the `@gridzero` named address).
# The module called is GRIDZERO_ADDR::game.
GRIDZERO_ADDR=

# Chain / endpoints (Initia mainnet)
INITIA_CHAIN_ID=interwoven-1
INITIA_REST=https://rest.initia.xyz
INITIA_RPC=https://rpc.initia.xyz

# Gas: denom uinit (6 decimals), min gas price 0.015uinit on interwoven-1.
GAS_PRICE=0.015uinit

# ── Signing key for the fulfiller wallet ────────────────────────────────────
# Provide EXACTLY ONE of these. This wallet signs resolve_round / skip_empty_round
# txs, so it is the game's own fulfiller and is expected to hold a key.
# Its `init1...` address must be set on-chain via gridzero::game::set_fulfiller
# and funded with INIT for gas.
RESOLVER_MNEMONIC=
# RESOLVER_PRIVATE_KEY=0x...   # hex (alternative to the mnemonic)

# ── Bot runtime ─────────────────────────────────────────────────────────────
PORT=8080
POLL_INTERVAL_MS=2000
