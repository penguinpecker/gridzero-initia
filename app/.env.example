# ── gridZERO on Initia mainnet (interwoven-1) ──

# Published Move package address (init1.../0x...) holding gridzero::game + gridzero::zero_token
NEXT_PUBLIC_GRIDZERO_ADDR=init1...

# Chain / network
NEXT_PUBLIC_INITIA_CHAIN_ID=interwoven-1
NEXT_PUBLIC_INITIA_REST=https://rest.initia.xyz
NEXT_PUBLIC_INITIA_RPC=https://rpc.initia.xyz

# $ZERO native fungible asset metadata address.
# Optional — if unset it is fetched on-chain via zero_token::metadata_address().
NEXT_PUBLIC_ZERO_METADATA=

# Resolver SSE stream (real-time round/cell events). Optional — SSE is skipped if unset.
NEXT_PUBLIC_RESOLVER_URL=

# Supabase round/player history (public anon reads). Optional — history no-ops if unset.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON=
